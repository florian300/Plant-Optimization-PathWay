# Python environments and cache
.venv/
venv/
__pycache__/
.pytest_cache/
*.py[cod]

# IDE and local tooling
.vscode/
.idea/

# Runtime logs and temp
logs/
tmp/
*.log

# Data files (never commit)
data/raw/**
data/processed/**
data/external/**
*.csv
*.tsv

# Solver/model artifacts (never commit)
*.lp
*.mps
*.sol
*.mst
*.ilp
main_output.txt
final_verify.txt
artifacts/**
Results/

# Legacy debug dump area
debug_scripts/
scripts/archive/**

# Keep placeholders if needed
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!artifacts/.gitkeep
!logs/.gitkeep